{
  "private": true,
  "version": "1.0.0",
  "name": "hoteliko-vweb",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "client": "cd client && npm run dev",
    "server": "cd server && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\" \"npm start\""
  },
  "build": {
    "appId": "com.anderson.hoteliko",
    "productName": "Hoteliko Logiciel",

    "files": [
      "client/dist/**/*",
      "electron/**/*",
      "server/**/*",
      "package.json"
    ],

    "extraResources": [
      {
        "from": "config.json",
        "to": "config.json"
      }
    ],

    "asar": false,

    "directories": {
      "output": "release"
    }
  },

  "dependencies": {
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@mui/icons-material": "^6.1.1",
    "@mui/material": "^6.1.9",
    "@mui/x-date-pickers": "^7.23.0",
    "@mui/x-date-pickers-pro": "^7.23.0",
    "axios": "^1.7.8",
    "concurrently": "^9.2.1",
    "dayjs": "^1.11.13",
    "electron": "^39.1.2",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "react": "^18.3.1",
    "react-confirm-alert": "^3.0.6",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.3.0",
    "react-router-dom": "^6.26.2",
    "react-toastify": "^10.0.5",
    "wait-on": "^9.0.3"
  },

  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.13.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "vite": "^5.4.10"
  }
}
